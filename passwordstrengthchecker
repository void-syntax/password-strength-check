password = input("Enter your password: ")

def is_password_good(password):
    counterof_uppercase = 0
    counterof_lowercase = 0
    counterof_digit = 0
    counterof_underscore = 0
    
    for char in password:
        if char.islower():
            counterof_lowercase += 1
        if char.isupper():
            counterof_uppercase += 1
        if char.isdigit():
            counterof_digit += 1
        if char == "_":
            counterof_underscore += 1
            
    counters = counterof_underscore + counterof_lowercase + counterof_digit + counterof_uppercase
    
    print("Your password is strong!!") if counters >= 4 else print("Your password is not good enough :(")

is_password_good(password)


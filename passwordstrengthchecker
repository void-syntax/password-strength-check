password = input("Enter your password: ")

def is_password_good(password):
    has_lowercase = False
    has_uppercase = False
    has_digit = False
    has_underscore = False
    
    for char in password:
        if char.islower():
            has_lowercase = True
        if char.isupper():
            has_uppercase = True
        if char.isdigit():
            has_digit = True
        if char == "_":
            has_underscore = True
            
    has_good_length = len(password) >= 8

    if has_good_length and has_lowercase and has_uppercase and has_digit and has_underscore:
        print("Your password is strong!!")
    else:
        print("Your password is not good enough :(")

is_password_good(password)

